---
const { id, size = 'default' } = Astro.props as {
  id: string;
  size?: 'default' | 'large';
};
---

<form data-address-form class={`address-form address-form--${size}`} novalidate>
  <div class="address-form__shell">
    <div class="address-form__field">
      <label class="sr-only" for={id}>Apartment viewing address</label>
      <span class="address-form__icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <path
            d="M10 17s5.5-4.5 5.5-9A5.5 5.5 0 1 0 4.5 8c0 4.5 5.5 9 5.5 9Z"
            stroke="currentColor"
            stroke-width="1.5"
          />
          <circle cx="10" cy="8" r="1.8" fill="currentColor" />
        </svg>
      </span>
      <input
        id={id}
        data-address-input
        type="text"
        inputmode="text"
        autocomplete="off"
        placeholder="Enter the apartment address"
        role="combobox"
        aria-autocomplete="list"
        aria-expanded="false"
        class="address-form__input"
      />
      <div class="address-form__panel" data-address-panel hidden>
        <ul class="address-form__list" data-address-list></ul>
      </div>
    </div>

    <button type="submit" class="address-form__button">
      <span class="address-form__button-icon" aria-hidden="true">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
          <circle cx="9" cy="9" r="6.5" stroke="currentColor" stroke-width="1.5" />
          <path d="m13.8 13.8 3.7 3.7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </span>
      Check availability
    </button>
  </div>

  <p class="address-form__status" data-address-status hidden></p>
</form>
